{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "composite": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "anod-core": ["../anod-core/src/index.ts"],
      "anod-core/internal": ["../anod-core/src/internal.ts"],
      "anod-core/internal-types": ["../anod-core/src/types.ts"]
    }
  },
  "references": [{ "path": "../anod-core" }],
  "include": ["src/**/*.ts"],
  "exclude": ["types/**", "test/**"]
}

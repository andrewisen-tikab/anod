{
  "name": "anod-list",
  "version": "0.5.0",
  "description": "Reactive array methods for anod",
  "keywords": [
    "array",
    "list",
    "reactive",
    "signals"
  ],
  "homepage": "https://github.com/visj/anod#readme",
  "bugs": {
    "url": "https://github.com/visj/anod/issues"
  },
  "license": "MIT",
  "author": "Vilhelm Sjölund",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visj/anod.git",
    "directory": "packages/list"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#test-runner": {
      "bun": "./test/env/bun.ts",
      "node": "./test/env/node.ts",
      "default": "./test/env/node.ts"
    },
    "#list": {
      "bun": "./src/list.ts",
      "default": "./dist/index.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./src": {
      "import": "./src/list.ts"
    }
  },
  "scripts": {
    "make": "bun scripts/build.js",
    "test": "bun test"
  },
  "devDependencies": {
    "anod-core": "workspace:*",
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.0.0"
  },
  "peerDependencies": {
    "anod-core": "^0.5.0"
  }
}

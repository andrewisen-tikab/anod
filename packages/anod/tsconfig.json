{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "composite": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "paths": {
      "anod-core": ["../anod-core/src/index.ts"],
      "anod-list": ["../anod-list/src/list.ts"]
    }
  },
  "references": [
    { "path": "../anod-core" },
    { "path": "../anod-list" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["types/**"]
}

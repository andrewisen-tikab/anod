{
  "name": "anod-core",
  "version": "0.5.0",
  "description": "Fast reactive signal library with built-in async support",
  "keywords": [
    "compute",
    "effect",
    "reactive",
    "signals",
    "state"
  ],
  "homepage": "https://github.com/visj/anod#readme",
  "bugs": {
    "url": "https://github.com/visj/anod/issues"
  },
  "license": "MIT",
  "author": "Vilhelm Sjölund",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/visj/anod.git",
    "directory": "packages/core"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "imports": {
    "#anod": {
      "src": "./src/index.js",
      "default": "./dist/index.js"
    },
    "#anod-src": "./src/index.js",
    "#test-runner": {
      "bun": "./test/env/bun.js",
      "node": "./test/env/node.js",
      "default": "./test/env/node.js"
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "src": "./src/index.js",
      "import": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "src": "./src/internal.js",
      "import": "./dist/internal.js"
    }
  },
  "scripts": {
    "make": "bun scripts/build.js",
    "test": "bun test"
  },
  "devDependencies": {
    "rolldown": "^1.0.0-rc.9",
    "terser": "^5.0.0"
  }
}
